# Firebase Web config (client — required for auth + progress persistence)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id

# Phase 1 feature flag for the AI smart-hint enhancement.
# Unset/true = AI hints on (default). Set to false (or 0/off/no) to disable AI
# entirely; the MVP and the escalating-hint ladder still work via deterministic
# fallbacks. Demonstrates that AI is an addition, not a replacement.
VITE_AI_HINTS_ENABLED=true
